# Palantir Console Configuration

# Server
PORT=4177

# Auth (optional — enables Bearer token auth + remote access)
# PALANTIR_TOKEN=my-secret-token

# Additional allowed CLI commands (comma-separated)
# PALANTIR_ALLOWED_COMMANDS=

# Fleet heartbeat (optional — enables SSH node reachability probes)
# PALANTIR_FLEET_HEARTBEAT=1
# PALANTIR_FLEET_HEARTBEAT_INTERVAL_MS=30000

# Anthropic (optional — for Manager Session)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=

# OpenCode (legacy)
# OPENCODE_STORAGE_HOST=~/.local/share/opencode/storage
