node_modules/
# Phase 10: server/plugins/ holds operator-placed Claude Code plugin
# directories referenced by Worker Presets. The directory tree itself is
# ignored — repo ships fixtures under server/tests/fixtures/plugins/ for CI.
server/plugins/
.env
.DS_Store
.sisyphus/
*.db
*.db-wal
*.db-shm
# DB backup snapshots (e.g. palantir.db.bak.<timestamp>) — never commit.
# These slipped into history once via a server boot worktree auto-save (git add -A).
*.bak
*.bak.*
.claude-auth.json
# Session lock written by the ao scheduler hook — ephemeral, per-machine.
# Tracking it made the hook emit `ao-wip(manual): remove scheduled_tasks.lock`
# churn commits on every session.
.claude/scheduled_tasks.lock
.ao/
.playwright-mcp/
.palantir-worktrees/
# Runtime (MCP configs, ephemeral)
runtime/
# Playwright
test-results/
playwright-report/
# node-gyp build artifacts (better-sqlite3 native module rebuild scratch).
# Created when prebuild-install falls back to source build; not a shipped
# artifact and varies per OS/Node ABI, so it must not enter version control.
build/
